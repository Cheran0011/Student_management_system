##EnrollmentRepository
---------------------

package com.cheran.student_management.repository;

import org.springframework.data.jpa.repository.JpaRepository;
import com.cheran.student_management.entity.Enrollment;
import java.util.List;

public interface EnrollmentRepository extends JpaRepository<Enrollment, Integer> {

    // ✅ Check if student already enrolled in a course
    boolean existsByStudentStudentIdAndCourseCourseId(int studentId, int courseId);

    // ✅ Get all enrollments for a specific student
    List<Enrollment> findByStudentStudentId(int studentId);
}

